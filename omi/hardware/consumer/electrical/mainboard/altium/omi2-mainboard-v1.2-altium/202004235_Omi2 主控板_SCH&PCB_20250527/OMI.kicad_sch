			(table_cell "1. Fixed the DCDC power enable control problem and reversed the enable logic\n2. Replaced the charging management chip with TI BQ25101 and added the battery charging temperature detection function\n3. Modified the battery installation method and improved the assembly process\n4. Added another microphone and modified the microphone installation method for easy assembly\n5. Added a rectifier bridge at the charging input to avoid reverse power connection during magnetic charging\n6. Added another LED to improve the light transmission effect"
				(exclude_from_sim no)
				(at 68.58 53.34 0)
				(size 113.03 40.64)
				(margins 0.9525 0.9525 0.9525 0.9525)
				(span 1 1)
				(fill
					(type none)
				)
				(effects
					(font
						(size 2 2)
					)
					(justify left)
				)
				(uuid "9d8df5e7-a792-4644-83ea-2f7b329bf028")
			)
